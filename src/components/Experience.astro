---
import { getCollection } from 'astro:content';
const experiences = await getCollection('experiences');
---

<section id="experience" class="mb-12 sm:mb-16 opacity-0 animate-[fadeIn_0.8s_ease_3s_forwards]">
  <h2 class="font-body font-normal text-cream text-[1.05rem] sm:text-[1.2rem] mb-5 sm:mb-6">Experience</h2>
  <div class="flex flex-col">
    {experiences.map(exp => (
      <div class="flex group">
        <div class="flex flex-col items-center">
          <div class="mt-2 w-2 h-2 rounded-full bg-ash flex-shrink-0 transition-all duration-300 group-hover:bg-parchment group-hover:shadow-[0_0_8px_rgba(201,169,110,0.4)]"></div>
          <div class="h-full w-0.5 bg-dust/30"></div>
        </div>
        <div class="pl-4 pb-6">
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-0 sm:gap-4 mb-0.5">
            <a href={exp.data.url} target="_blank" rel="noopener noreferrer"
               class="font-body font-normal text-cream/90 text-[0.95rem] sm:text-[1.1rem] hover:text-parchment transition-colors">
              {exp.data.role}
            </a>
            <span class="font-body text-[0.75rem] sm:text-[0.9rem] text-ash whitespace-nowrap">{exp.data.time}</span>
          </div>
          <p class="font-body italic text-[0.8rem] sm:text-[0.95rem] text-ash mb-1">{exp.data.id}</p>
          <p class="font-body text-cream/50 text-[0.85rem] sm:text-[1rem] leading-[1.7]">{exp.data.job}</p>
        </div>
      </div>
    ))}
  </div>
</section>