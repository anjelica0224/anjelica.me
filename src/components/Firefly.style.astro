    50%  { transform: translateX(-34vw) translateY(12vh)  scale(0.71); }
    75%  { transform: translateX(8vw)   translateY(30vh)  scale(0.86); }
    100% { transform: translateX(35vw)  translateY(-49vh) scale(0.75); }
  }
