<style is:inline>
  .firefly {
    position: fixed; left: 50%; top: 50%;
    width: 0.4vw; height: 0.4vw;
    margin: -0.2vw 0 0 9.8vw;
    animation: ease 200s alternate infinite;
    pointer-events: none;
  }
