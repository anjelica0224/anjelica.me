    border-radius: 50%; transform-origin: -10vw;
  }
  .firefly::before { background: black; opacity: 0.4; animation: drift ease alternate infinite; }
  .firefly::after  { background: white; opacity: 0; box-shadow: 0 0 0vw 0vw #c9a96e; animation: drift ease alternate infinite, flash ease infinite; }

  .firefly:nth-child(1)  { animation-name: move1; }
