---
const { title, header, profile } = Astro.props;
---

<section class="relative h-80 md:h-[55vh] w-full mb-24">

  <div class="absolute inset-0 overflow-hidden">
    <img
      class="w-full h-full object-cover opacity-60"
      src={header}
      alt=""
    />
    <div class="absolute inset-0 bg-gradient-to-b from-ink/40 via-transparent to-ink/90"></div>
  </div>

  <div class="waves absolute bottom-0 left-0 w-full z-10 overflow-hidden">
    <svg
      class="waves-svg"
      viewBox="0 24 150 28"
      preserveAspectRatio="none"
      shape-rendering="auto"
    >
      <defs>
        <path
          id="gentle-wave"
          d="M-160 44c30 0 58-18 88-18s 58 18 88 18 58-18 88-18 58 18 88 18 v44h-352z"
        />
      </defs>
      <g class="parallax">
        <use href="#gentle-wave" x="48" y="0"  class="wave-layer opacity-25" style="animation-delay:-2s; animation-duration:7s;" />
        <use href="#gentle-wave" x="48" y="20" class="wave-layer opacity-50" style="animation-delay:-3s; animation-duration:10s;" />
        <use href="#gentle-wave" x="48" y="5"  class="wave-layer opacity-75" style="animation-delay:-4s; animation-duration:13s;" />
        <use href="#gentle-wave" x="48" y="7"  class="wave-layer"            style="animation-delay:-5s; animation-duration:20s;" />
      </g>
    </svg>
  </div>

  <!-- profile + title -->
  <div
    id="masthead-profile"
    class="flex flex-col w-1/2 mx-auto absolute z-30 inset-x-1/5 transition-all duration-300"
    style="top: 75%;"
  >
    <div class="flex flex-col items-center w-max">
      {profile && (
        <img
          class="rounded-full md:size-[150px] size-[90px] object-cover ring-1 ring-parchment/20 shadow-[0_0_40px_rgba(201,169,110,0.15)]"
          src={profile}
          alt={title ?? ''}
        />
      )}
      {title && (
        <span class="font-display font-light text-fog text-2xl md:text-4xl text-center pt-3 tracking-[0.08em]">
          {title}
        </span>
      )}
    </div>
  </div>

</section>

<script>
  const profile = document.getElementById('masthead-profile');

  if (profile) {
    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY;
      // starts fading at 50px scroll, fully gone by 200px
      const opacity = Math.max(0, 1 - scrollY / 200);
      const translateY = scrollY * 0.3; // slight upward drift as it fades

      profile.style.opacity = String(opacity);
      profile.style.transform = `translateY(-${translateY}px)`;
    }, { passive: true });
  }
</script>