---
import { IoLogoGithub } from 'react-icons/io5';
import { IoLogoLinkedin } from "react-icons/io";
import { IoLogoTwitter } from "react-icons/io";
import { AiOutlineMail } from "react-icons/ai";
---

<header class="fixed top-0 left-0 right-0 z-50 flex justify-between items-center px-6 sm:px-10 py-5">

  <nav class="hidden sm:flex items-center gap-8">
    <a href="/#about"    class="font-galaxy text-[0.45rem] tracking-[0.25em] uppercase text-ash hover:text-parchment transition-colors duration-300">About</a>
    <a href="/#projects" class="font-galaxy text-[0.45rem] tracking-[0.25em] uppercase text-ash hover:text-parchment transition-colors duration-300">Works</a>
    <a href="/blog"      class="font-galaxy text-[0.45rem] tracking-[0.25em] uppercase text-ash hover:text-parchment transition-colors duration-300">Writing</a>
    <a href="/gallery"   class="font-galaxy text-[0.45rem] tracking-[0.25em] uppercase text-ash hover:text-parchment transition-colors duration-300">Gallery</a>
    <a href="/cv"        class="font-galaxy text-[0.45rem] tracking-[0.25em] uppercase text-ash hover:text-parchment transition-colors duration-300">CV</a>
  </nav>

  <div class="flex items-center gap-4">
    <a href="https://github.com/anjelica0224" target="_blank" aria-label="GitHub"
       class="text-ember hover:text-parchment transition-colors duration-300">
      <IoLogoGithub className="w-[15px] h-[15px]"/>
    </a>
    <a href="https://www.linkedin.com/in/anjelica-b64844211/" target="_blank" aria-label="LinkedIn"
       class="text-ember hover:text-parchment transition-colors duration-300">
      <IoLogoLinkedin className="w-[15px] h-[15px]"/>
    </a>
    <a href="https://x.com/dysphoricsimon" target="_blank" aria-label="Twitter"
       class="text-ember hover:text-parchment transition-colors duration-300">
      <IoLogoTwitter className="w-[15px] h-[15px]"/>
    </a>
    <a href="mailto:hi@anjelica.me" aria-label="Email"
       class="text-ember hover:text-parchment transition-colors duration-300">
      <AiOutlineMail className="w-[15px] h-[15px]"/>
    </a>
  </div>
</header>