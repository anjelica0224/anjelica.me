---
import { getCollection, type CollectionEntry } from 'astro:content';
import SiteLayout from './SiteLayout.astro';
import Gallery from '../components/Gallery.astro';

type Props = CollectionEntry<'blog'>['data'];
const { title, description, pubDate, updatedDate, heroImage, otherImages, rightImages, layout } = Astro.props;
---
<SiteLayout headerImage={heroImage} currentPage="blog">
  <div class="sm:grid sm:grid-cols-4 gap-4">
    <aside class="md:w-3/5 hidden md:flex md:flex-col left-4" >
      <img src="/up.webp" class="mt-20 scale-280 ml-18 ">
      <img src="/all.webp" class="scale-280 mt-20 mb-20 ml-20"/>
      <img src="/aya.webp" class="rounded-2xl ml-16 mt-20 scale-150"/>
    </aside>
    <article class="md:col-span-2 col-span-4 px-20 md:px-6 mb-40">
      <span class="text-cream md:text-4xl font-galaxy font-extrabold text-2xl">{title}</span>
      <div class="mt-8">
        <slot/>
      </div>
    </article>
    <aside class="mt-20 sm:w-4/5 hidden md:flex md:flex-col" >
      {console.log(otherImages)}
      <Gallery cols={layout?.[0]} images={otherImages} right={rightImages}/>
      <img src="/edgar.webp" class="mt-8 opacity-80"/>
      <iframe class="mt-20" data-testid="embed-iframe" style="border-radius:12px" src="https://open.spotify.com/embed/track/1cPLddXCqw6uzyWy6tdtlK?utm_source=generator" width="100%" height="152" allowfullscreen="" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>
      <div class="grow"></div>
    </aside>
  </div>
  
</SiteLayout>
		