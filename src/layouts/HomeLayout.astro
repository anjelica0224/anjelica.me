---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Firefly from '../components/Firefly.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import Footer from '../components/Footer.astro';
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-ink">
    <div id="loading-screen" class="fixed inset-0 z-[10000] flex items-end justify-end" aria-hidden="true">
      <img
        src="/header-image.webp"
        alt=""
        class="absolute inset-0 w-full h-full object-cover"
        style="filter: blur(6px) brightness(0.4); transform: scale(1.05);"
      />
      <div class="absolute inset-0 bg-ink/50"></div>

      <div class="relative m-8 sm:m-12">
        <div class="loading-ring"></div>
        <img
          src="/anjelica.webp"
          alt="Anjelica"
          class="relative w-20 h-20 sm:w-24 sm:h-24 rounded-full object-cover z-10"
        />
      </div>
    </div>

    <div id="page-content" class="opacity-0">
      <div class="grain" aria-hidden="true"></div>
      <div class="vignette" aria-hidden="true"></div>
      <Firefly />
      <Header currentPage="home" />
      <main>
        <slot />
      </main>
    </div>



    <script>
      const hasLoaded = sessionStorage.getItem('hasLoaded');
      const loader = document.getElementById('loading-screen');
      const content = document.getElementById('page-content');

      if (hasLoaded) {
        if (loader) loader.remove();
        if (content) {
          content.classList.remove('opacity-0');
          content.classList.add('visible');
        }
        document.querySelectorAll<HTMLElement>('[class*="animate-[fadeIn"]').forEach(el => {
          el.classList.remove('opacity-0');
          el.style.opacity = '1';
          el.style.animation = 'none';
        });
      } else {
        window.addEventListener('load', () => {
          setTimeout(() => {
            if (loader) loader.classList.add('fade-out');
            if (content) content.classList.add('visible');
            sessionStorage.setItem('hasLoaded', '1');
          }, 1500);
        });
      }
    </script>
  </body>
  <Footer>
</html>